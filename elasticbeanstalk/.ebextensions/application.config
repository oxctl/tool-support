files:
  "/opt/application/config/application-client.properties":
    mode: "000755"
    owner: root
    group: root
    authentication: "S3Auth"
    source: 'https://s3-`{ "Ref" : "AWS::Region"}`.amazonaws.com/elasticbeanstalk-`{"Ref": "AWS::Region"}`-`{"Ref": "AWS::AccountId"}`/files/`{"Fn::GetOptionSetting": {"Namespace": "aws:elasticbeanstalk:application:environment", "OptionName": "HOSTNAME"}}`-client.properties'
    
  "/opt/application/config/jwk.jks":
    mode: "000755"
    owner: root
    group: root
    authentication: "S3Auth"
    source: 'https://s3-`{ "Ref" : "AWS::Region"}`.amazonaws.com/elasticbeanstalk-`{"Ref": "AWS::Region"}`-`{"Ref": "AWS::AccountId"}`/files/`{"Fn::GetOptionSetting": {"Namespace": "aws:elasticbeanstalk:application:environment", "OptionName": "HOSTNAME"}}`.jks'
