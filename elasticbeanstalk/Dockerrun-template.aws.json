{
  "AWSEBDockerrunVersion": "2",
  "containerDefinitions": [
    {
      "name": "application",
      "image": "${IMAGE}",
      "essential": true,
      "memory": 768,
      "memoryReservation": 512,
      "portMappings": [
        {
          "hostPort": 80,
          "containerPort": 8080
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/${APP_NAME}-app",
          "awslogs-region": "${AWS_REGION}",
          "awslogs-stream-prefix": "${APP_NAME}"
        }
      }
    }
  ]
}
